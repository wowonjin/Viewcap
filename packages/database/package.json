{
  "name": "@viewcap/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "migrate": "prisma migrate dev",
    "push": "prisma db push",
    "push:sqlite": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "seed": "tsx prisma/seed.ts",
    "seed:sqlite": "cross-env DATABASE_URL=file:./prisma/dev.db tsx prisma/seed.ts",
    "build": "prisma generate && tsc",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "prisma": "^6.11.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
