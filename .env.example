DATABASE_URL=file:./packages/database/prisma/dev.db
REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOCAL_STORAGE=true

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# S3/MinIO (production). Leave S3_ENDPOINT empty to use local file storage.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=viewcap
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

OPENAI_API_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
DEV_AUTH_ENABLED=true
DEV_AUTH_EMAIL=demo@viewcap.local
ADMIN_EMAILS=admin@viewcap.local

# Production Postgres example:
# DATABASE_URL=postgresql://viewcap:viewcap@localhost:5432/viewcap
# LOCAL_STORAGE=false
# S3_ENDPOINT=http://localhost:9000
